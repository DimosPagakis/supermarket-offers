# Public API base. Override locally to point at your backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Public canonical URL used by robots.txt + sitemap.xml.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "true" to bypass the live API and serve hard-coded sample data
# from src/mocks/. Useful when the backend is not yet running.
NEXT_PUBLIC_USE_MOCKS=false
